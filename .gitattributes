# Exclude from GitHub language stats

# JavaScript — generated/config files only
*.js linguist-generated=true
*.js linguist-detectable=false
*.mjs linguist-generated=true
*.mjs linguist-detectable=false

# Docker
Dockerfile linguist-detectable=false
*.dockerfile linguist-detectable=false

# Prisma generated client
src/prisma/prismaClient/** linguist-generated=true
src/prisma/schema/** linguist-generated=true
